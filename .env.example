# Copia este archivo como .env y completa los valores para tu entorno.
# En producción (Vercel), configura estas variables en el dashboard del proyecto.
#
# OBLIGATORIAS:
# VITE_API_URL — URL base de la API del backend (sin barra final)

# Desarrollo local:
VITE_API_URL=http://localhost:8000/api/

# Producción (ejemplo Render):
# VITE_API_URL=https://pos-system-wfog.onrender.com/api
